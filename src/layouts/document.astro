---
import Footer from "@/components/footer.astro";
import Header from "@/components/header.astro";
import Head from "@/components/head.astro";
import { site } from "@/consts";

import ButtonScrollTop from "@/components/button-scroll-top.astro";

interface Props {
  title?: string;
  description?: string | null;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang={site.lang} class="motion-safe:scroll-smooth size-full">
  <Head title={title ? `${title} | ${site.name}` : site.name} description={description ?? ""} />

  <body class="relative size-full flex flex-col font-sans antialiased bg-background prose max-w-full dark:prose-invert">
    <Header />
    <main class="flex-1 pt-32">
      <slot />
    </main>
    <Footer />
    <ButtonScrollTop />
  </body>
</html>
