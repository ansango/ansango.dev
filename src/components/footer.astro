---
import Container from "@/components/container.astro";
import Divider from "@/components/divider.astro";
import GithubIcon from "@/components/icons/github-icon.astro";
import RssIcon from "./icons/rss-icon.astro";
import { site } from "@/consts";
---

<footer class="pb-10">
  <Container>
    <Divider />
  </Container>
  <Container className="py-5 flex items-center gap-2 !space-y-0">
    <a href="https://github.com/ansango" target="_blank">
      <GithubIcon />
    </a>
    <a href={site.url + "/rss.xml"} target="_blank"> <RssIcon /> </a>
    <a href="https://anibalsantosgomez.com" target="_blank" class="font-medium">me</a>
  </Container>
</footer>
