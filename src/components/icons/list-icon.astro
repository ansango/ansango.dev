---
import Svg from "../svg.astro";

interface Props {
  className?: string;
}

const { className } = Astro.props;
---

<Svg id="list-icon" className={className}>
  <path
    fill="none"
    stroke="currentColor"
    stroke-linecap="round"
    stroke-linejoin="round"
    stroke-width="2"
    d="m16 6l4 14M12 6v14M8 8v12M4 4v16"></path>
</Svg>
