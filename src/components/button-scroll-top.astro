---
import ArrowUp from "./icons/arrow-up.icon.astro";
---

<div class="fixed w-full bottom-5">
  <div class="max-w-screen-md mx-auto flex justify-end px-5">
    <button
      id="scroll-to-top"
      class="opacity-0 pointer-events-none transition-all duration-300 ease-in-out rounded-full shadow-md bg-background"
      ><ArrowUp className="size-8" /></button
    >
  </div>
</div>
